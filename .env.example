# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_APP_SECRET=your_app_secret_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here

# Cloud LLM — Primary (free tier)
GROQ_API_KEY=your_groq_api_key_here

# Cloud LLM — Fallback 1
OPENROUTER_API_KEY=your_openrouter_key_here

# Cloud LLM — Fallback 2
ZAI_API_KEY=your_zai_key_here

# Vision (for image messages)
OPENAI_API_KEY=your_openai_key_here

# Voice TTS (optional)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Embeddings
HF_API_KEY=your_huggingface_key_here

# Web Search
BRAVE_SEARCH_API_KEY=your_brave_key_here
TAVILY_API_KEY=your_tavily_key_here

# On-premise models (optional — falls back to cloud if offline)
LLAMA_BRAIN_URL=http://localhost:8080
LLAMA_ROUTER_URL=http://localhost:8081

# Database — Railway provides this automatically
DATABASE_URL=postgresql://user:password@host:5432/waxprep

# Redis — Railway provides this automatically
REDIS_URL=redis://localhost:6379

# App
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
ADMIN_KEY=your_secret_admin_key_here
