# Meta WhatsApp
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_APP_SECRET=your_app_secret_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Security
# Leave empty to allow all IPs. For production, use Meta's published ranges.
ALLOWED_IP_RANGES=31.13.65.0/24,31.13.66.0/24,66.220.144.0/20
RATE_LIMIT_PER_PHONE=30
RATE_LIMIT_GLOBAL=1000

# Encryption - Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here

# Database
DATABASE_URL=postgresql+asyncpg://user:password@db.neon.tech/waxprep?ssl=require

# Redis
REDIS_URL=redis://default:password@redis.upstash.io:6379

# Worker
AI_TEAM_WEBHOOK_URL=https://your-ai-team.com/api/v1/incoming
